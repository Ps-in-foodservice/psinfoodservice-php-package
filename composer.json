{
    "name": "psinfoodservice/psinfoodserviceapi",
    "description": "A comprehensive PHP client library for the PS in foodservice Web API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5|^10.0",
        "mockery/mockery": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "PSinfoodservice\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PSinfoodservice\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage"
    }
}
